  "options": {
    "step": {
      "init": {
        "title": "Energy data for the heat pump",
        "description": "Map Home Assistant sensors so the bridge can feed the heat pump. Grid sensors drive PV-surplus optimisation (grid power, negative = export); PV and battery sensors are shown on the device's display. Each section's power sensor enables that provider; the rest are optional. Leave a power sensor empty to disable that push.",
        "data": {
          "grid_power_entity": "Grid power sensor (negative = export/surplus)",
