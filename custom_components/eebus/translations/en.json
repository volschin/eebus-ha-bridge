          "grid_consumption_energy_entity": "Grid consumption energy sensor (optional)",
          "pv_power_entity": "PV power sensor",
          "pv_yield_energy_entity": "PV yield energy sensor (optional)",
          "pv_peak_power_entity": "PV nominal peak power sensor (optional)",
          "battery_power_entity": "Battery power sensor (negative = charging)",
