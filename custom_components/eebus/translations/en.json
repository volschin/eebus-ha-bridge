      "incompatible_api_version": "The EEBUS bridge API major version is incompatible with this integration.",
      "invalid_ski": "Enter a valid 40-character hexadecimal SKI.",
      "required": "This field is required for TLS + token mode.",
      "ski_is_local": "That is the bridge's own SKI. Enter the heat pump's SKI instead."
    },
    "abort": {
      "already_configured": "This device is already configured.",
      "already_in_progress": "Configuration flow is already in progress.",
      "not_eebus_bridge": "Discovered SHIP device does not expose the EEBUS bridge gRPC API.",
