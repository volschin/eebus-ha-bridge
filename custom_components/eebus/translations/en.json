{
  "config": {
    "flow_title": "EEBUS Bridge ({host})",
    "step": {
      "user": {
        "title": "Connect to EEBUS Bridge",
        "description": "Enter bridge address and test connection.",
        "data": {
          "grpc_host": "Bridge Host",
          "grpc_port": "Bridge Port"
        }
      },
      "security": {
        "title": "Secure the bridge connection",
        "description": "Use loopback only when Home Assistant and the bridge share the same host. Remote bridges require TLS, the issuing CA certificate in PEM format, and an authentication token.",
