          "security_mode": "Security mode",
          "tls_ca_certificate": "TLS CA certificate (PEM)",
          "auth_token": "Authentication token"
        }
      },
      "device": {
        "title": "Select EEBUS Device",
        "description": "Pick a discovered device or enter its SKI manually.",
        "data": {
          "device_ski": "Device SKI"
        }
      },
      "reconfigure": {
        "title": "Reconfigure EEBUS Bridge",
        "description": "Change bridge connection parameters.",
        "data": {
          "grpc_host": "Bridge Host",
          "grpc_port": "Bridge Port"
        }
      },
      "reconfigure_security": {
        "title": "Reconfigure bridge security",
        "description": "Enter the TLS settings. Leave the token blank to keep the current token.",
        "data": {
          "security_mode": "Security mode",
          "tls_ca_certificate": "TLS CA certificate (PEM)",
          "auth_token": "New authentication token (optional)"
        }
      },
      "reauth_confirm": {
        "title": "Reconnect to the EEBUS bridge",
        "description": "Authentication failed. Enter the current CA certificate and a new authentication token.",
        "data": {
          "tls_ca_certificate": "TLS CA certificate (PEM)",
          "auth_token": "Authentication token"
        }
      }
    },
    "error": {
      "cannot_connect": "Cannot connect to EEBUS bridge. Check the address and port.",
      "tls_trust": "TLS trust failed. Check that the CA certificate matches the bridge certificate.",
      "invalid_auth": "Authentication failed. Check the bridge token.",
